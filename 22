local ParticleLayer = Instance.new("Frame")
ParticleLayer.Size = UDim2.new(1, 0, 1, 0)
ParticleLayer.BackgroundTransparency = 1
ParticleLayer.BorderSizePixel = 0
ParticleLayer.ZIndex = 14
ParticleLayer.Parent = ScreenGui

local activeParticles = 0
local MAX_PARTICLES = 30

local function createParticle(position, color)
    if activeParticles >= MAX_PARTICLES then return end
    activeParticles = activeParticles + 1

    local p = Instance.new("Frame")
    p.Size = UDim2.new(0, math.random(4, 10), 0, math.random(4, 10))
    p.AnchorPoint = Vector2.new(0.5, 0.5)
    p.Position = position
    p.BackgroundColor3 = color
    p.BorderSizePixel = 0
    p.ZIndex = 15
    p.Parent = ParticleLayer

    local pc = Instance.new("UICorner")
    pc.CornerRadius = UDim.new(1, 0)
    pc.Parent = p
    return p
end

local function destroyParticle(p)
    if p and p.Parent then
        p:Destroy()
    end
    activeParticles = math.max(0, activeParticles - 1)
end

