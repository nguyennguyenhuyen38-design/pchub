                local tweenA = TweenService:Create(particle, TweenInfo.new(0.25, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {Position = midPos, BackgroundTransparency = 0.1, Rotation = math.random(-180, 180)})
                local tweenB = TweenService:Create(particle, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Position = endPos, BackgroundTransparency = 1, Size = UDim2.new(0, 1, 0, 1), Rotation = math.random(-360, 360)})
                tweenA.Completed:Connect(function() tweenB:Play() end)
                tweenB.Completed:Connect(function() destroyParticle(particle) end)
                tweenA:Play()
            end)
        end

        TweenService:Create(LogoButton, TweenInfo.new(0.45, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {ImageTransparency = 0, BackgroundTransparency = 0.25}):Play()
        tweenCenterContent(1, 0.2)
        task.wait(0.25)
        CenterFrame.Visible = false
        for _, obj in ipairs(centerTextObjects) do
            obj.TextTransparency = 0
        end
        stroke.Transparency = 0
    end

    notify("Black Screen", blackScreenEnabled and "BAT (FPS "..FPS_CAP..")" or "TAT (FPS 60)", 2, LOGO_IMAGE_ID)
    transitionBusy = false
end

